{
  "appId": "go2-autonomy",
  "version": "0.1.1",
  "platform": "linux/arm64",
      "frameworks": {
        "ros2": {
          "distro": "jazzy",
          "domainId": 30,
          "rmw": "cyclonedds"
        }
      },
      "entitlements": [
        { "type": "network", "mode": "host" },
        { "type": "camera" },
        { "type": "gpu" },
        { "type": "persist", "name": "maps", "path": "/maps" },
        { "type": "persist", "name": "data", "path": "/data" }
      ]
}
